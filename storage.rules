rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId} {
      // Profile pictures are publicly readable
      allow read: if true;
      
      // Only the owner can upload/update their own avatar
      // Validates: 
      // 1. User is authenticated
      // 2. Authentication UID matches the path
      // 3. File size is under 5MB
      // 4. Content type is an image
      allow write: if request.auth != null 
                    && request.auth.uid == userId 
                    && request.resource.size < 5 * 1024 * 1024 
                    && request.resource.contentType.matches('image/(jpeg|png|webp|jpg)');
    }

    match /curriculum/media/{userId}/{fileName} {
      // Curriculum media is readable by authenticated users (teachers, managers, students)
      allow read: if request.auth != null;

      // Only the uploader (manager/admin) can write their own media
      // Validates:
      // 1. User is authenticated
      // 2. Authentication UID matches the path
      // 3. File size is under 100MB
      // 4. Content type is audio or video
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 100 * 1024 * 1024
                    && (request.resource.contentType.matches('audio/.*')
                        || request.resource.contentType.matches('video/.*'));
    }

    match /curriculum/lessons/{lessonId}/media/{fileName} {
      // Lesson media is readable by authenticated users
      allow read: if request.auth != null;

      // Only Admins and Managers can upload lesson media
      allow write: if request.auth != null
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'manager')
                    && request.resource.size < 100 * 1024 * 1024
                    && (request.resource.contentType.matches('audio/.*')
                        || request.resource.contentType.matches('video/.*'));
    }

    match /curriculum/lessons/{lessonId}/images/{fileName} {
      // Lesson images are readable by authenticated users
      allow read: if request.auth != null;

      // Only Admins and Managers can upload inline images (max 5MB)
      allow write: if request.auth != null
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'manager')
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|png|webp|jpg|gif)');
    }

    match /courses/covers/{fileName} {
      // Course covers are publicly readable
      allow read: if true;
      
      // Only Admins and Managers can upload course covers
      allow write: if request.auth != null 
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'manager')
                    && request.resource.size < 5 * 1024 * 1024 
                    && request.resource.contentType.matches('image/(jpeg|png|webp|jpg)');
    }

    match /notebooks/{notebookId}/{userId}/{fileName} {
      // Notebook images and audio recordings are readable by authenticated users
      allow read: if request.auth != null;
      
      // Validates:
      // 1. User is authenticated and matches the folder userId
      // 2. File size is under 15MB (to accommodate audio recordings)
      // 3. Content type is a standard web image or an audio file
      allow write: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 15 * 1024 * 1024 
                    && (request.resource.contentType.matches('image/(jpeg|png|webp|jpg|gif)')
                        || request.resource.contentType.matches('audio/.*'));
    }

    match /notebooks/audio/{userId}/{fileName} {
      // Notebook audios are readable by authenticated users
      allow read: if request.auth != null;
      
      // Validates:
      // 1. User is authenticated and matches the folder userId
      // 2. File size is under 8MB (8 * 1024 * 1024)
      // 3. Content type is an audio file
      allow write: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 8 * 1024 * 1024 
                    && request.resource.contentType.matches('audio/.*');
    }

    match /certificates/{studentId}/{fileName} {
      // Certificates are readable by the student owner and staff (admins/managers)
      allow read: if request.auth != null 
                   && (request.auth.uid == studentId 
                       || request.auth.token.role == 'admin' 
                       || request.auth.token.role == 'manager');
      
      // Uploads are handled via Server API (Firebase Admin SDK)
      allow write: if false; 
    }

    match /documents/{userId}/{allPaths=**} {
      // Documents are only accessible by the owner
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /payouts/{teacherId}/receipts/{fileName} {
      // Receipts are visible to the teacher and staff, but only writable by staff
      allow read: if request.auth != null 
                   && (request.auth.uid == teacherId 
                       || request.auth.token.role == 'admin' 
                       || request.auth.token.role == 'manager');
      allow write: if request.auth != null 
                    && (request.auth.token.role == 'admin' || request.auth.token.role == 'manager')
                    && request.resource.size < 10 * 1024 * 1024
                    && (request.resource.contentType.matches('application/pdf') 
                        || request.resource.contentType.matches('image/.*'));
    }
  
    match /payouts/{teacherId}/invoices/{fileName} {
      // Invoices (Notas Fiscais) can be read and written by both the teacher and staff (admin/manager)
      allow read: if request.auth != null 
                   && (request.auth.uid == teacherId 
                       || request.auth.token.role == 'admin' 
                       || request.auth.token.role == 'manager');
      allow write: if request.auth != null 
                    && (request.auth.uid == teacherId 
                        || request.auth.token.role == 'admin' 
                        || request.auth.token.role == 'manager')
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType == 'application/pdf';
    }
  }
}
